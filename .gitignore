app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Firebase config files — each developer downloads their own from Firebase Console
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
lib/firebase_options.dart

# Private API Configuration
lib/utils/api_config.dart

# Xcode SwiftPM state (regenerated automatically)
ios/Runner.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
ios/Runner.xcworkspace/xcshareddata/swiftpm/
macos/Runner.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
macos/Runner.xcworkspace/xcshareddata/swiftpm/
# Generated Flutter plugin registrants
linux/flutter/generated_plugin_registrant.*
linux/flutter/generated_plugins.cmake

windows/flutter/generated_plugin_registrant.*
windows/flutter/generated_plugins.cmake

macos/Flutter/GeneratedPluginRegistrant.swift

# Web-specific generated files
lib/generated_plugin_registrant.dart
android/build/
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
macos/Flutter/Generated.xcconfig
macos/Flutter/flutter_export_environment.sh

